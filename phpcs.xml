<?xml version="1.0"?>
<ruleset name="WooCopy AI">
	<description>WordPress Coding Standards ruleset for WooCopy AI.</description>

	<file>.</file>
	<exclude-pattern>*/admin/build/*</exclude-pattern>
	<exclude-pattern>*/admin/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>

	<arg value="sp"/>
	<arg name="basepath" value="."/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>

	<rule ref="WordPress">
		<exclude name="WordPress.Files.FileName"/>
	</rule>

	<rule ref="WordPress-Extra"/>
	<rule ref="WordPress-Docs"/>

	<config name="minimum_supported_wp_version" value="6.3"/>
	<config name="testVersion" value="8.0-"/>

	<rule ref="PHPCompatibilityWP"/>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="woocopy"/>
				<element value="WooCopy"/>
			</property>
		</properties>
	</rule>
</ruleset>
